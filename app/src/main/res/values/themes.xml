<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 
        TEMA DA SPLASH SCREEN - TELA DE ABERTURA
        ========================================
        Este tema é aplicado à tela de abertura (splash screen) do aplicativo.
        Utiliza a API SplashScreen para uma experiência moderna e consistente.
    -->
    <style name="Theme.EcoLab.Splash" parent="Theme.SplashScreen">
        <!-- Cor de fundo da splash screen -->
        <item name="windowSplashScreenBackground">@color/background_primary</item>
        
        <!-- Ícone centralizado da splash screen (usando o invólucro para evitar cortes) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        
        <!-- Cor da barra de status durante a splash screen -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_primary</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/background_primary</item>

        <!-- Tema a ser aplicado após a splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.EcoLab</item>
    </style>

    <!-- 
        TEMA PRINCIPAL - ECOLAB MATERIAL DESIGN 3
        =========================================
        Tema base que define toda a identidade visual do aplicativo.
    -->
    <style name="Theme.EcoLab" parent="Theme.Material3.DayNight">
        <!-- Cores primárias -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        
        <!-- Cores secundárias -->
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>
        
        <!-- Cores terciárias -->
        <item name="colorTertiary">@color/tertiary_color</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>
        
        <!-- Cores de erro -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>
        
        <!-- Cores de superfície -->
        <item name="colorSurface">@color/surface_primary</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        
        <!-- Cores de fundo -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
        
        <!-- Cores de contorno -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>
        
        <!-- Barras do sistema -->
        <item name="android:statusBarColor">@color/primary_color</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/surface_primary</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Propriedades da janela -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        
        <!-- Estilos de componentes customizados -->
        <item name="materialCardViewStyle">@style/Widget.EcoLab.CardView</item>
        <item name="materialButtonStyle">@style/Widget.EcoLab.Button</item>
        <item name="textInputStyle">@style/Widget.EcoLab.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.EcoLab.BottomNavigationView</item>
    </style>
    
    <!-- Estilos de componentes -->
    <style name="Widget.EcoLab.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface_primary</item>
        <item name="rippleColor">@color/ripple_surface</item>
    </style>
    
    <style name="Widget.EcoLab.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="rippleColor">@color/ripple_primary</item>
    </style>

    <style name="Widget.EcoLab.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary_color</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>
    
    <style name="Widget.EcoLab.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="elevation">8dp</item>
        <item name="itemRippleColor">@color/ripple_surface</item>
    </style>

</resources>
